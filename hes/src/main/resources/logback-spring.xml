<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true">

    <property name="LOG_DIR" value="logs"/>
    <property name="SERVER_TIMEZONE" value="${server.timezone:-}"/>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS, ${SERVER_TIMEZONE}} %-5level [%thread] [%X{hes.quartz.fireInstanceId:-}] %logger - %msg%n" />

    <!-- ==== 1. Console Appender (Restores IntelliJ Logs) ==== -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ==== 2. Main Appender (logs/app-main.log) ==== -->
    <appender name="MAIN_DATED_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/app-main.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/app-main-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <cleanHistoryOnStart>true</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <!-- ==== 3. Application Appender (applications/application.log) ==== -->
    <appender name="APP_FOLDER_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/applications/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/applications/application-%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <!-- ==== 4. DLMS Meter Appender (Restores meters/ folder) ==== -->
    <appender name="DLMS_APPENDER" class="ch.qos.logback.classic.sift.SiftingAppender">
        <discriminator>
            <key>meter</key>
            <defaultValue>general</defaultValue>
        </discriminator>
        <sift>
            <appender name="METER_FILE_APPENDER" class="ch.qos.logback.core.rolling.RollingFileAppender">
                <file>${LOG_DIR}/meters/${meter}-dlms-txrx.log</file>
                <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                    <fileNamePattern>${LOG_DIR}/meters/${meter}-dlms-txrx-%d{yyyy-MM-dd}.log</fileNamePattern>
                    <maxHistory>1</maxHistory>
                </rollingPolicy>
                <encoder>
                    <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS, ${SERVER_TIMEZONE}} %-5level %msg%n</pattern>
                </encoder>
            </appender>
        </sift>
    </appender>

    <!-- ==== Async Wrappers ==== -->
    <appender name="ASYNC_MAIN" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="MAIN_DATED_FILE"/>
    </appender>

    <appender name="ASYNC_APP" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="APP_FOLDER_FILE"/>
    </appender>

    <appender name="ASYNC_DLMS" class="ch.qos.logback.classic.AsyncAppender">
        <appender-ref ref="DLMS_APPENDER"/>
    </appender>

    <!-- ==== Loggers (The missing links) ==== -->

    <!-- Restore Meter Logging -->
    <logger name="DLMS-TXRX" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_DLMS"/>
    </logger>

    <!-- Restore Root Logging (Console + Both Main Files) -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="ASYNC_MAIN"/>
        <appender-ref ref="ASYNC_APP"/>
    </root>

</configuration>